{
  "_meta": {
    "name": "ABBEY default behavioral configuration",
    "version": "0.1",
    "state_range": "Most internal states are smooth variables intended to stay between 0 and 1.",
    "pressure_units": "per hour",
    "scale_explanation": "In the smooth update x_next = x + dt * (up * (1 - x) - down * x), a pressure of 1.0 is strong. With dt=0.25 h and x=0.5, up=1.0 increases x by about +0.125 in one timestep. A pressure of 0.05 is weak and slow."
  },

  "hunger": {
    // Natural hunger accumulation while awake.
    // 0.045 = weak hourly hunger growth.
    "base_up": 0.045,

    // Hunger grows slower during sleep.
    // 0.35 means only 35% of normal hunger growth while sleeping.
    "sleep_multiplier": 0.35,

    // Fatigue can mildly increase hunger/food urge.
    // If fatigue=1, this adds +0.015 per hour.
    "fatigue_to_hunger_up": 0.015,

    // Eating strongly reduces hunger.
    // 1.20 is strong: with dt=0.25 and hunger=0.5, it reduces hunger by about -0.15.
    "eat_simple_down": 1.20,
    "cook_down": 1.10,
    "emergency_eat_down": 0.90,
    // Cooking implies eating, but slower/less immediate than eat_simple.
    "cook_down": 0.80
  },

  "fatigue": {
    // Baseline fatigue drift.
    "base_up": 0.010,

    // Extra fatigue accumulation when awake.
    "awake_up": 0.025,

    // If hunger=1, adds +0.070 per hour to fatigue pressure.
    "hunger_to_fatigue_up": 0.030,

    // Sickness is a strong fatigue driver.
    // If sickness_severity=1, adds +0.180 per hour.
    "sickness_to_fatigue_up": 0.180,

    "thermal_discomfort_to_fatigue_up": 0.025,
    "air_quality_discomfort_to_fatigue_up": 0.020,
    "acoustic_discomfort_to_fatigue_up": 0.010,

    // Active actions increase fatigue.
    // Multiplied by action.activity_intensity.
    "activity_intensity_to_fatigue_up": 0.025,

    // Sleeping strongly reduces fatigue.
    "sleep_down": 0.550,

    // Doing nothing gives mild fatigue recovery.
    "rest_down": 0.050
  },

  "sleep_pressure": {
    "base_up": 0.010,

    // Fatigue is the main driver of sleep pressure.
    "fatigue_to_sleep_up": 0.160,

    // Night signal is between 0 and 1.
    "night_to_sleep_up": 0.260,
    "awake_duration_to_sleep_up": 0.85,
    "awake_duration_center_minutes": 960,
    "awake_duration_width_minutes": 180,

    // Sickness increases sleep pressure.
    "sickness_to_sleep_up": 0.120,

    // Sleeping reduces sleep pressure.
    "sleep_down": 0.650,

    // Daytime wakefulness reduces sleep pressure slightly.
    "daytime_awake_down": 0.120
  },

  "sickness": {
    // For v0.1, sickness does not appear randomly yet.
    // It only recovers if initial sickness_severity > 0.
    "spontaneous_up": 0.000,

    // 0.035 = slow recovery over days.
    "recovery_down": 0.035
  },

  "dirty_clothes": {
    // Natural accumulation of dirty clothes.
    "base_up": 0.012,

    // Being home creates slightly more dirty clothes.
    "home_up": 0.006,

    // Sickness can increase dirty clothes generation.
    "sickness_to_dirty_clothes_up": 0.010,

    // Washing machine strongly reduces dirty clothes.
    "washing_machine_down": 0.900
  },

  "action_friction": {
    // Fatigue increases resistance to initiating actions.
    "fatigue_to_friction_up": 0.180,

    // Sickness also increases action friction.
    "sickness_to_friction_up": 0.140,

    // Sleep pressure makes effortful actions less attractive.
    "sleep_pressure_to_friction_up": 0.080,

    // Natural recovery of action friction.
    "base_down": 0.030,

    // Sleeping recovers action friction faster.
    "sleep_down": 0.120
  },
  "space_exit_rules": {
      "auto_turn_lights_off_when_empty": true
    },
  "perception": {
        "thermal": {
          // Fanger PMV-based thermal perception.
          // PMV = 0 means neutral.
          // PMV = -1 means slightly cold.
          // PMV = +1 means slightly warm.
          // PPD is derived from PMV and gives predicted dissatisfaction percentage.
        
          "met": 1.1,
          "clo": 0.8,
          "air_velocity_m_s": 0.1,
          "relative_humidity_percent": 50.0,
        
          // For v0.1, MRT is assumed equal to indoor air temperature.
          "mean_radiant_temp_equals_air_temp": true,
        
          // If sickness_severity=1, perceived PMV shifts by -0.5,
          // meaning the person feels colder.
          "sickness_pmv_cold_shift": 0.5,
        
          // How fast thermal_discomfort follows PPD-derived dissatisfaction.
          "response_up": 0.80,
          "response_down": 0.70
        },

        "air_quality": {
          "comfortable_co2_ppm": 800.0,
          "co2_stress_scale_ppm": 700.0,
          "sickness_sensitivity_multiplier": 0.50,
          "response_up": 0.90,
          "response_down": 0.80
        },
    
        "visual": {
          "required_daylight": 0.40,
          "artificial_light_equivalent": 0.80,
          "daylight_stress_scale": 0.30,
          "response_up": 0.70,
          "response_down": 0.90
        },
    
        "acoustic": {
          "comfortable_noise": 0.35,
          "noise_stress_scale": 0.30,
          "response_up": 0.70,
          "response_down": 0.60
        }
  },
  
  "circadian": {
      // Simplified melatonin-like signal.
      // 0 = no biological night pressure, 1 = strong night pressure.
    
      "melatonin_onset_hour": 21.5,
      "melatonin_peak_hour": 2.5,
      "melatonin_offset_hour": 7.5,
    
      // Higher = sharper transition between day/night.
      "transition_steepness": 2.5,
    
      // Chronotype shift in hours.
      // Positive = later sleeper, negative = earlier sleeper.
      "chronotype_shift_h": 0.0,
    
      // Work obligation is not forced. It only increases pressure to be awake/leave.
      "work_start_hour": 8.5,
      "work_end_hour": 18.0,
      "work_transition_h": 1.0
    },
    
    "idle_movement_profiles": {
  "_meta": {
    "description": "Ambient/random room movement when occupant is home, awake, idle, and not blocked by a foreground action.",
    "transition_probability_per_hour": "Base probability per hour that an idle person considers changing space.",
    "minimum_dwell_minutes": "Minimum time before another random room change is allowed.",
    "role_transition_matrix": "Markov matrix between semantic space roles, not building-specific room IDs."
  },

  "normal": {
    "transition_probability_per_hour": 0.35,
    "minimum_dwell_minutes": 20,

    "role_transition_matrix": {
      "idle": {
