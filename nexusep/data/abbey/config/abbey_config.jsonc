      },

      "entrance": {
        "idle": 1.0
      }
    }
  },

  "restless": {
    "transition_probability_per_hour": 0.75,
    "minimum_dwell_minutes": 8,

    "role_transition_matrix": {
      "idle": {
        "idle": 0.40,
        "kitchen": 0.30,
        "sleep": 0.15,
        "bathroom": 0.15
      },

      "kitchen": {
        "idle": 0.65,
        "kitchen": 0.15,
        "bathroom": 0.10,
        "sleep": 0.10
      },

      "sleep": {
        "idle": 0.70,
        "sleep": 0.15,
        "bathroom": 0.15
      },

      "work": {
        "work": 0.55,
        "idle": 0.25,
        "kitchen": 0.20
      },

      "bathroom": {
        "idle": 0.80,
        "kitchen": 0.10,
        "sleep": 0.10
      },

      "laundry": {
        "idle": 0.85,
        "laundry": 0.15
      },

      "entrance": {
        "idle": 1.0
      }
    }
  },

  "sedentary": {
    "transition_probability_per_hour": 0.15,
    "minimum_dwell_minutes": 45,

    "role_transition_matrix": {
      "idle": {
        "idle": 0.85,
        "kitchen": 0.10,
        "bathroom": 0.05
      },

      "kitchen": {
        "idle": 0.85,
        "kitchen": 0.10,
        "bathroom": 0.05
      },

      "sleep": {
        "idle": 0.70,
        "sleep": 0.25,
        "bathroom": 0.05
      },

      "work": {
        "work": 0.85,
        "idle": 0.10,
        "kitchen": 0.05
      },

      "bathroom": {
        "idle": 0.95,
        "bathroom": 0.05
      },

      "laundry": {
        "idle": 0.95,
        "laundry": 0.05
      },

      "entrance": {
        "idle": 1.0
      }
    }
  }
},
"actions": {
  "_meta": {
    "duration_minutes": "Real duration of the action. The simulation converts it to timestep chunks.",
    "execution_type": "control = changes system/person state; foreground = occupies the actor; background = runs while actor can do other things; passive = filler/rest.",
    "blocks_actor": "If true, the person cannot start another foreground action during this action.",
    "background_process": "If true, the action continues in parallel, e.g. washing machine.",
    "can_continue_without_actor": "If true, the process can continue even if the person leaves home.",
    "can_be_interrupted": "If true, the action/process can be stopped before completion.",
    "activity_intensity": "0 = no physical/mental effort, 1 = very intense.",
    "effort": "0 = no initiation resistance, 1 = very hard to initiate.",
    "power_w": "Direct appliance/control power during the action. Building-performance module may add HVAC/lighting/etc separately."
  },

