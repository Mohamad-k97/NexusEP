"decision": {
  "_meta": {
    "scale": "Scores are relative. Higher score means the action is more likely to be chosen. Values around 0.1 are weak, 1.0 is meaningful, 3.0 is strong."
  },

  "do_nothing_bias": 0.01,

  "hunger_food_weight": 3.0,
  "cook_hunger_threshold": 0.55,
  "cook_bonus_above_threshold": 2.00,
  "eat_simple_bonus": 0.25,
  "hot_drink_sickness_weight": 0.80,
  "sleep_initiation_melatonin_gate": 0.75,
    "early_sleep_penalty": 3.0,
    "early_sleep_end_hour": 21.5,
    "extreme_fatigue_for_early_sleep": 0.85,
    "extreme_sleep_pressure_for_early_sleep": 0.90,
    "sleep_after_long_sleep_penalty": 2.5,
    "long_sleep_threshold_fatigue": 0.25,
    "long_sleep_threshold_sleep_pressure": 0.25,
    "force_return_home_after_work": true,
"return_home_work_pressure_threshold": 0.20,
"return_home_after_work_bonus": 50.0,
  "sleep_drive_weight": 3.0,
  "wake_drive_weight": 3.0,
