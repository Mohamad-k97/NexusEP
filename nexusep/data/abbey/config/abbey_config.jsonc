        "bathroom": 0.05
      },

      "work": {
        "work": 0.70,
        "idle": 0.20,
        "kitchen": 0.10
      },

      "bathroom": {
        "idle": 0.85,
        "bathroom": 0.05,
        "kitchen": 0.05,
        "sleep": 0.05
      },

      "laundry": {
        "idle": 0.90,
